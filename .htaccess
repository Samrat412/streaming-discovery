# StreamFlix .htaccess Configuration
# URL Rewriting and Security

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [L,R=301]
    
    # Rewrite movie URLs
    RewriteRule ^movie/([0-9]+)/?$ pages/movie-detail.php?id=$1 [QSA,L]
    
    # Rewrite TV URLs
    RewriteRule ^tv/([0-9]+)/?$ pages/tv-detail.php?id=$1 [QSA,L]
    
    # Rewrite watch URLs
    RewriteRule ^watch/movie/([0-9]+)/?$ pages/watch-movie.php?id=$1 [QSA,L]
    RewriteRule ^watch/tv/([0-9]+)/?$ pages/watch-tv.php?id=$1 [QSA,L]
    
    # Rewrite browse URLs
    RewriteRule ^browse/([a-z-]+)/?$ pages/browse.php?type=$1 [QSA,L]
    
    # Rewrite search
    RewriteRule ^search/?$ pages/search.php [QSA,L]
    
    # Rewrite collections
    RewriteRule ^collections/?$ pages/collections.php [QSA,L]
    
    # Block direct access to includes
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^lib/ - [F,L]
    RewriteRule ^api/tmdb.php - [F,L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'"
</IfModule>

# Disable directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Cache Control
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    
    # HTML (don't cache)
    ExpiresByType text/html "access plus 1 day"
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>
